# Copy to .env and fill in. .env is gitignored.

# TTS provider: "mock" (default, no keys) or "openai"
TTS_PROVIDER=openai

# Required when TTS_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Defaults shown; users can override the voice prompt per request from the app
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar

# Where the light SQLite DB (job status) and synthesized audio files live.
# Defaults to a gitignored .data/ dir next to the server. DB_PATH/AUDIO_DIR
# derive from DATA_DIR unless set explicitly.
DATA_DIR=.data
# DB_PATH=.data/readcast.db
# AUDIO_DIR=.data/audio
